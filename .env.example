APP_NAME=RoadSoS Backend
ENVIRONMENT=development
API_VERSION=1.2.0
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/roadsos
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/roadsos_test
REDIS_URL=

SECRET_KEY=change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
MESH_RELAY_SIGNING_KEY=
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
ALLOWED_HOSTS=*
TRUST_PROXY_HEADERS=false
MAX_UPLOAD_BYTES=1048576
MAX_MESH_PAYLOAD_BYTES=4096

RATE_LIMIT_DEFAULT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_SOS_PER_MINUTE=3
RATE_LIMIT_RAG_PER_MINUTE=20
RATE_LIMIT_RELAY_PER_MINUTE=20
RATE_LIMIT_VOICE_PER_MINUTE=5

ESCALATION_TIER1_SECONDS=90
ESCALATION_TIER2_SECONDS=180
ESCALATION_TIER3_SECONDS=300
ESCALATION_DEMO_MODE=false

TASK_QUEUE_BACKEND=database
TASK_WORKER_POLL_SECONDS=1.5
TASK_LOCK_TIMEOUT_SECONDS=900
TASK_WORKER_CONCURRENCY=4
REQUIRE_REDIS_IN_PRODUCTION=false

FIELD_ENCRYPTION_KEYS=
FIELD_ENCRYPTION_REQUIRED_IN_PRODUCTION=true
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_TOKEN=

FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_JSON=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SMS_FALLBACK_ENABLED=true
SMS_FALLBACK_NUMBER=112

RAG_TOP_K_SEMANTIC=8
RAG_TOP_K_KEYWORD=8
RAG_MAX_CONTEXT_CHARS=6000
RAG_MIN_CONFIDENCE=0.18
RAG_EMBEDDING_DIM=768
RAG_EMBEDDING_PROVIDER=hashing
RAG_LLM_PROVIDER=extractive
RAG_LLM_ENABLED=false
RAG_EMBEDDING_TIMEOUT_SECONDS=20
RAG_EMBEDDING_RETRIES=2
RAG_LLM_TIMEOUT_SECONDS=10
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_CHAT_MODEL=gemini-2.5-flash-lite
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
